# Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# ── Database ──────────────────────────────────────────────
# Get a free PostgreSQL database at:
#   - https://neon.tech (Recommended - serverless, works great with Vercel)
#   - https://supabase.com
DATABASE_URL=postgresql://user:password@host:5432/novahr?sslmode=require

# ── JWT Secrets ────────────────────────────────────────────
# Use a strong random string - generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_use_a_long_random_string_here
JWT_REFRESH_SECRET=CHANGE_ME_use_a_different_long_random_string_here

# JWT Expiry Settings (optional, defaults below)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── AI Copilot (Free) ─────────────────────────────────────
# Get a free Gemini API key at: https://aistudio.google.com/app/apikey
# Without this key, the copilot runs in rule-based offline fallback mode
GEMINI_API_KEY=your_gemini_api_key_here

# ── Email (Free Tier) ─────────────────────────────────────
# Get a free Resend API key at: https://resend.com (3000 emails/month free)
# Without this key, verification emails are logged to console only
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── App Settings ──────────────────────────────────────────
NODE_ENV=development
PORT=8000

# URL of the frontend app (used for CORS)
FRONTEND_URL=http://localhost:3000

# ── Vercel (Production Only) ──────────────────────────────
# These are set via the Vercel dashboard - not needed locally
# VERCEL_URL is auto-populated by Vercel
